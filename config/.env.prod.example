# SmartSRE Copilot production environment template
# Copy to .env and replace every placeholder before deploying.

# Application
APP_NAME=SmartSRE Copilot
APP_VERSION=0.1.0.dev0
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=9900

# CORS: production must use explicit origins only. Do not use "*".
CORS_ALLOWED_ORIGINS=https://sre.example.com

# Database
POSTGRES_DSN=postgresql://smartsre:<replace-with-strong-postgres-password>@postgres:5432/smartsre
POSTGRES_CONNECT_TIMEOUT_SECONDS=5

# Redis and worker queue
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_BACKEND=redis
TASK_DISPATCHER_MODE=detached
REDIS_TASK_QUEUE_NAME=smartsre:indexing:queue
INDEXING_TASK_MAX_RETRIES=3

# API authentication
# Use a high-entropy value from a secret manager. Placeholder/default secrets are rejected in production.
APP_API_KEY=<replace-with-high-entropy-api-key>
# API_KEYS_JSON={"viewer-key":"viewer","operator-key":"operator","knowledge-key":"knowledge_admin","admin-key":"admin"}

# DashScope / Qwen
DASHSCOPE_API_KEY=<replace-with-real-dashscope-api-key>
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Vector store
VECTOR_STORE_BACKEND=pgvector
PGVECTOR_COLLECTION_NAME=biz

# Object storage
OBJECT_STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio-app:9000
MINIO_ACCESS_KEY=<replace-with-minio-access-key>
MINIO_SECRET_KEY=<replace-with-minio-secret-key>

# Agent runtime
AGENT_DECISION_PROVIDER=qwen
AGENT_MAX_STEPS=5
AGENT_TOTAL_TIMEOUT_SECONDS=120

# OpenTelemetry tracing
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# MCP servers
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://cls-mcp:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://monitor-mcp:8004/mcp
MCP_TOOLS_LOAD_TIMEOUT_SECONDS=8
