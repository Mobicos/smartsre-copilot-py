# SmartSRE Copilot — Production environment template
# Copy to .env and fill in real values before deploying.

# Application
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=9900

# CORS: explicit origins only in production
CORS_ALLOWED_ORIGINS=https://sre.example.com

# Database
POSTGRES_DSN=postgresql://smartsre:<password>@postgres:5432/smartsre

# Redis
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_BACKEND=redis
TASK_DISPATCHER_MODE=detached

# API authentication
APP_API_KEY=<generate-a-secure-key>

# DashScope / Qwen
DASHSCOPE_API_KEY=<your-dashscope-api-key>
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Vector store
VECTOR_STORE_BACKEND=pgvector
PGVECTOR_COLLECTION_NAME=biz

# Object storage
OBJECT_STORAGE_BACKEND=local

# Agent runtime
AGENT_DECISION_PROVIDER=deterministic
AGENT_MAX_STEPS=5
AGENT_TOTAL_TIMEOUT_SECONDS=120

# OpenTelemetry (set OTEL_ENABLED=true to activate)
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# MCP servers
# MCP_CLS_URL=http://cls-mcp:8003/mcp
# MCP_MONITOR_URL=http://monitor-mcp:8004/mcp
