# SmartSRE Copilot — Staging environment template
# Copy to .env and adjust for your staging environment.

# Application
ENVIRONMENT=staging
DEBUG=false
HOST=0.0.0.0
PORT=9900

# CORS
CORS_ALLOWED_ORIGINS=https://staging-sre.example.com,http://localhost:3000

# Database
POSTGRES_DSN=postgresql://smartsre:<password>@postgres:5432/smartsre

# Redis
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_BACKEND=redis
TASK_DISPATCHER_MODE=detached

# API authentication
APP_API_KEY=<staging-api-key>

# DashScope / Qwen
DASHSCOPE_API_KEY=<your-dashscope-api-key>
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Vector store
VECTOR_STORE_BACKEND=pgvector
PGVECTOR_COLLECTION_NAME=biz

# Object storage
OBJECT_STORAGE_BACKEND=local

# Agent runtime
AGENT_DECISION_PROVIDER=deterministic
AGENT_MAX_STEPS=5
AGENT_TOTAL_TIMEOUT_SECONDS=120
