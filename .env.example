# SmartSRE Copilot local development environment template

# Application
APP_NAME=SmartSRE Copilot
APP_VERSION=0.1.0.dev0
ENVIRONMENT=dev
DEBUG=false
HOST=0.0.0.0
PORT=9900
CORS_ALLOWED_ORIGINS=http://localhost:9900,http://127.0.0.1:9900
POSTGRES_DSN=postgresql://smartsre:dev-only-postgres-password@postgres:5432/smartsre
POSTGRES_PASSWORD=dev-only-postgres-password
POSTGRES_CONNECT_TIMEOUT_SECONDS=5
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_BACKEND=redis
TASK_DISPATCHER_MODE=detached
REDIS_TASK_QUEUE_NAME=smartsre:indexing:queue
INDEXING_TASK_MAX_RETRIES=3
APP_API_KEY=replace_with_a_secure_key_for_local_dev
# API_KEYS_JSON={"viewer-key":"viewer","operator-key":"operator","knowledge-key":"knowledge_admin","admin-key":"admin"}

# DashScope / Qwen
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Object Storage (MinIO)
OBJECT_STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9002
# Local development only. Use unique credentials in production.
MINIO_ACCESS_KEY=dev-only-minio-user
MINIO_SECRET_KEY=dev-only-minio-password
MINIO_ROOT_USER=dev-only-minio-user
MINIO_ROOT_PASSWORD=dev-only-minio-password

# Milvus (optional vector-milvus profile)
# MILVUS_HOST=standalone
# MILVUS_PORT=19530
# MILVUS_TIMEOUT=10000

# RAG
RAG_TOP_K=3
RAG_MODEL=qwen-max

# Document chunking
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# MCP servers
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp
MCP_TOOLS_LOAD_TIMEOUT_SECONDS=8

# Agent runtime
# Local smoke and tests default to deterministic to avoid requiring a real model key.
# Production deployments should use config/.env.prod.example and AGENT_DECISION_PROVIDER=qwen.
AGENT_DECISION_PROVIDER=deterministic
AGENT_MAX_STEPS=5
AGENT_TOTAL_TIMEOUT_SECONDS=120
